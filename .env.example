# ─── Infrastructure ───────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=main_db

REDIS_PASSWORD=redis_password
REDIS_PORT=6379

MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin_password

# ─── Auth Service ─────────────────────────────────────────────────────────────
AUTH_SERVICE_PORT=3001
AUTH_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auth_db?schema=public
AUTH_REDIS_URL=redis://:redis_password@localhost:6379
JWT_ACCESS_SECRET=your-super-secret-access-key-minimum-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Identity Service ─────────────────────────────────────────────────────────
IDENTITY_SERVICE_PORT=3002
IDENTITY_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/identity_db?schema=public

# ─── Gateway ──────────────────────────────────────────────────────────────────
GATEWAY_PORT=3000
AUTH_SERVICE_URL=http://localhost:3001
IDENTITY_SERVICE_URL=http://localhost:3002
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100
