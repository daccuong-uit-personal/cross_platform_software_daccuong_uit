# ─── Common / Runtime Settings ─────────────────────────────────────────────────
# NODE_ENV: development / production / test
NODE_ENV=development
# LOG_LEVEL: control log verbosity in all services
LOG_LEVEL=info
# Browser origin allowed by CORS for all services
CORS_ORIGIN=http://localhost:5173

# ─── Infrastructure ───────────────────────────────────────────────────────────
# PostgreSQL credentials and default database for local development
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# Redis connection for cache / session data
REDIS_PASSWORD=redis_password
REDIS_PORT=6379

# MongoDB root credentials for local development
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin_password

# ─── Auth Service ─────────────────────────────────────────────────────────────
# AUTH_SERVICE_PORT: local listening port for auth service
AUTH_SERVICE_PORT=3001
# AUTH_DATABASE_URL: postgres connection string for auth service data
AUTH_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auth_db?schema=public
# AUTH_REDIS_URL: redis connection used by auth service
AUTH_REDIS_URL=redis://:redis_password@localhost:6379
# JWT secrets must be long, random, and kept private in production
JWT_ACCESS_SECRET=your-super-secret-access-key-minimum-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# IDENTITY_SERVICE_URL: endpoint gateway/auth use to call identity service
IDENTITY_SERVICE_URL=http://localhost:3002

# ─── Identity Service ─────────────────────────────────────────────────────────
# IDENTITY_SERVICE_PORT: local listening port for identity service
IDENTITY_SERVICE_PORT=3002
# IDENTITY_DATABASE_URL: postgres connection string for identity service data
IDENTITY_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/identity_db?schema=public
# NOTE: Identity service uses JWT_ACCESS_SECRET from the auth service section above.

# ─── Media Service ────────────────────────────────────────────────────────────
# MEDIA_SERVICE_PORT: local listening port for media service
MEDIA_SERVICE_PORT=3003
# MEDIA_DATABASE_URL: postgres connection string for media service data
MEDIA_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/media_db?schema=public
# Shared Redis connection for media service
REDIS_URL=redis://:redis_password@localhost:6379
# MinIO credentials for local object storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=media

# ─── Gateway ──────────────────────────────────────────────────────────────────
# GATEWAY_PORT: local listening port for API gateway
GATEWAY_PORT=3000
AUTH_SERVICE_URL=http://localhost:3001
IDENTITY_SERVICE_URL=http://localhost:3002
MEDIA_SERVICE_URL=http://localhost:3003
# Rate limiting settings for gateway
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100
