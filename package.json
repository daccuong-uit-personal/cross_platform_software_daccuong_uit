{
  "name": "cross-platform-software",
  "private": true,
  "description": "Production-Oriented Social + Commerce + Creator Ecosystem",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "docker-compose -f infra/docker/docker-compose.yaml up -d",
    "stop": "docker-compose -f infra/docker/docker-compose.yaml down",
    "lint": "turbo run lint",
    "build": "turbo run build",
    "test": "turbo run test"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "turbo": "latest",
    "typescript": "^5.0.0"
  },
  "packageManager": "npm@11.14.1"
}
